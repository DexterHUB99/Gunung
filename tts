-- ════════════════════════════════════
--  LOAD DICTIONARY
--  Dictionary.Words = {["WORD"]=true,...} sudah ada di memory
--  Akses via getgc() scan
-- ════════════════════════════════════
local wordSet = nil
local dictReady = false

local function loadDictionary()
    -- Cara 1: getgc() scan cari table dengan key "Words" berisi hashtable kata
    if getgc then
        for _, v in ipairs(getgc(true)) do
            if type(v) == "table" then
                -- Dictionary module punya .Words (table) dan .Contains (function) dan .Load (function)
                local ok = pcall(function()
                    if type(v.Words) == "table"
                    and type(v.Contains) == "function"
                    and type(v.Load) == "function" then
                        -- Verifikasi: cek ada kata-kata di Words
                        local count = 0
                        for _ in pairs(v.Words) do
                            count = count + 1
                            if count > 5 then break end
                        end
                        if count > 0 then
                            wordSet = v.Words
                            dictReady = true
                        end
                    end
                end)
                if dictReady then break end
            end
        end
        if dictReady then
            local count = 0
            for _ in pairs(wordSet) do count = count + 1 end
            print("[Dict] Loaded via getgc:", count, "kata")
            return true, "getgc ("..count.." kata)"
        end
    end

    -- Cara 2: require DictionaryWords langsung (array of strings)
    local ok2, res2 = pcall(function()
        local SharedMod = ReplicatedStorage:WaitForChild("SharedModules", 3)
        local DW = require(SharedMod:WaitForChild("DictionaryWords", 3))
        if type(DW) == "table" and #DW > 0 then
            wordSet = {}
            for _, word in ipairs(DW) do
                local w = tostring(word):upper():gsub("%s+","")
                if #w >= 3 and w:match("^[A-Z]+$") then
                    wordSet[w] = true
                end
            end
            dictReady = true
        end
    end)
    if dictReady then
        local count = 0
        for _ in pairs(wordSet) do count = count + 1 end
        print("[Dict] Loaded via DictionaryWords:", count, "kata")
        return true, "DictionaryWords ("..count.." kata)"
    end

    -- Cara 3: require Dictionary module
    local ok3, res3 = pcall(function()
        local SharedMod = ReplicatedStorage:WaitForChild("SharedModules", 3)
        local Dict = require(SharedMod:WaitForChild("Dictionary", 3))
        if Dict and type(Dict.Words) == "table" then
            wordSet = Dict.Words
            dictReady = true
        end
    end)
    if dictReady then
        local count = 0
        for _ in pairs(wordSet) do count = count + 1 end
        return true, "require Dictionary ("..count.." kata)"
    end

    return false, "Semua cara gagal"
end

local function isWord(w)
    if not dictReady or not wordSet then return false end
    return wordSet[w:upper()] == true
end

