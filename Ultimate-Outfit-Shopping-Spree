    if input.UserInputType == Enum.UserInputType.MouseButton1 then sliding = false end
end)
uis.InputChanged:Connect(function(input)
    if sliding and input.UserInputType == Enum.UserInputType.MouseMovement then
        local mouseX = input.Position.X
        local bgPos = SliderBG.AbsolutePosition.X
        local bgSize = SliderBG.AbsoluteSize.X
        local percent = math.clamp((mouseX - bgPos) / bgSize, 0, 1)
        SliderFill.Size = UDim2.new(percent, 0, 1, 0)
        delayMs = math.floor(minDelay + (maxDelay - minDelay) * percent)
        SliderLabel.Text = "Teleport Delay: " .. delayMs .. " ms"
    end
end)

-- ============================================
-- FUNGSI PENCARI DIAMOND (fix untuk Model)
-- ============================================
local DIAMOND_NAMES = {"CoinGiver", "Diamond", "diamond", "Coin", "coin"}

local function getPrimaryOrAnyPart(obj)
    -- Kalau Model, ambil PrimaryPart atau part pertama
    if obj:IsA("Model") then
        if obj.PrimaryPart then
            return obj.PrimaryPart
        end
        for _, v in pairs(obj:GetDescendants()) do
            if v:IsA("BasePart") then return v end
        end
    elseif obj:IsA("BasePart") then
        return obj
    end
    return nil
end

local function getTargetItems()
    local items = {}
    for _, obj in pairs(workspace:GetChildren()) do
        for _, name in pairs(DIAMOND_NAMES) do
            if obj.Name == name then
                local part = getPrimaryOrAnyPart(obj)
                if part then
                    table.insert(items, part)
                end
                break
            end
        end
    end
    return items
end

-- ============================================
-- AUTO FARM LOGIC
-- ============================================
local autoFarm = false

ToggleBtn.MouseButton1Click:Connect(function()
    autoFarm = not autoFarm
    if autoFarm then
        ToggleBtn.Text = "Auto Farm: ON"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(50, 180, 50)

        task.spawn(function()
            while autoFarm do
                local targets = getTargetItems()
                StatusLabel.Text = "Diamonds found: " .. #targets

                for _, target in ipairs(targets) do
                    if not autoFarm then break end

                    local character = player.Character
                    if character and character:FindFirstChild("HumanoidRootPart") then
                        -- Teleport tepat di atas diamond agar trigger touch
                        character.HumanoidRootPart.CFrame = target.CFrame * CFrame.new(0, 2, 0)
                    end

                    task.wait(math.max(delayMs / 1000, 0.01))
                end

                task.wait(0.1)
            end
            StatusLabel.Text = "Diamonds found: 0"
        end)
    else
        ToggleBtn.Text = "Auto Farm: OFF"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
    end
end)
