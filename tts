local function lenColor(n)
    if n<=3 then return Color3.fromRGB(130,130,210) end
    if n==4 then return Color3.fromRGB(60,175,255) end
    if n==5 then return Color3.fromRGB(55,215,125) end
    if n==6 then return Color3.fromRGB(255,190,40) end
    if n==7 then return Color3.fromRGB(255,115,55) end
    return Color3.fromRGB(255,65,115)
end

